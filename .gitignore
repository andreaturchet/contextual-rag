# Secure-LLMOps Pipeline - Git Ignore File
# =========================================

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================================
# Virtual Environments
# =============================================================================
venv/
ENV/
env/
.venv/

# =============================================================================
# IDE / Editor
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# =============================================================================
# Testing
# =============================================================================
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.hypothesis/

# =============================================================================
# Data and Models (don't commit large files)
# =============================================================================
data/vectordb/
data/models/
*.bin
*.pt
*.pth
*.onnx
*.h5

# Keep sample_docs but ignore actual documents
data/sample_docs/*.pdf
data/sample_docs/*.docx
!data/sample_docs/.gitkeep
!data/sample_docs/example.txt

# =============================================================================
# Logs
# =============================================================================
logs/
*.log

# =============================================================================
# Environment Variables (may contain secrets)
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# Docker
# =============================================================================
docker-compose.override.yml
